rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return true; // Relaxed for custom demo auth
    }

    function isAdmin() {
      return true; // Relaxed for custom demo auth
    }

    function isOwner(userId) {
      return true; // Relaxed for custom demo auth
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if true; // TEMPORARY DEV BYPASS FOR CUSTOM AUTH DEMO
    }
  }
}
