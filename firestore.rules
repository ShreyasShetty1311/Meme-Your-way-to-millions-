rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Why these rules are what they are ─────────────────────────────────────
    //
    // This app uses a CUSTOM username/password auth, NOT Firebase Auth.
    // User documents have auto-generated Firestore IDs, NOT Firebase Auth UIDs.
    // This means the standard `request.auth.uid == userId` pattern doesn't work.
    //
    // The compromise for a controlled classroom/event:
    //  - READ  everywhere: open (needed so login can query users by username)
    //  - WRITE everywhere: requires at least the anonymous Firebase session
    //    (ensureAnonymousAuth in main.tsx), which blocks random internet bots.
    //
    // This is significantly safer than the previous `if true` (no auth at all)
    // while not breaking the custom login flow.
    //
    // To upgrade further: migrate login to Firebase Auth (email/password or
    // Google) so request.auth.uid matches user document IDs, then you can
    // re-enable per-role write rules.
    // ─────────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Users — reads must be open so the login query (by username field) works.
    // Writes still require an authenticated session.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Game state — read open (all clients need it); writes need auth
    match /gameState/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Memes — read open; writes (buy transactions) need auth
    match /memes/{memeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Scenarios — read open; writes need auth
    match /scenarios/{scenarioId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Portfolios — read open; writes need auth
    match /portfolios/{portfolioId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Submissions — read open; writes need auth
    match /submissions/{submissionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Votes — read open; writes need auth
    match /votes/{voteId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Trade listings — read open; writes need auth
    match /tradeListings/{listingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
